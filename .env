# .env

# --- Google Maps API Configuration ---
# Get your API key from the Google Cloud Console: https://console.cloud.google.com/
GOOGLE_MAPS_API_KEY="YOUR_GOOGLE_MAPS_API_KEY_HERE"

# --- Study Configuration ---
# Use any format Google Maps can understand (e.g., "1600 Amphitheatre Parkway, Mountain View, CA" or "42.3601,-71.0589")
START_POINT="Fenway Park, Boston, MA"
END_POINT="Gillette Stadium, Foxborough, MA"

# --- Application Settings ---
# Interval in minutes to collect data
COLLECTION_INTERVAL_MINUTES=5
# Total duration in days for the study to run
STUDY_DURATION_DAYS=14