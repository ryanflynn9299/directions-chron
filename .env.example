# .env.example
# Copy this file to .env and fill in the values below.

# --- Google Maps API Configuration ---
# Get your API key from the Google Cloud Console: https://console.cloud.google.com/
GOOGLE_MAPS_API_KEY="YOUR_GOOGLE_MAPS_API_KEY_HERE"
# MOCK_API_CALLS="true" # Set to true to bypass Google Maps API and return random durations

# --- Optional Overrides ---
# System defaults are configured in config.yaml.
# You can override specific default routes here if running the application without payloads.
# START_POINT="Fenway Park, Boston, MA"
# END_POINT="Gilette Stadium, Foxboro, MA"
# COLLECT_RETURN_TRIP="true"